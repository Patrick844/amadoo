# ── Copy this to .env and fill in your values ────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amadoo

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# Local file storage — photos saved here and served at BASE_URL/uploads/
# UPLOADS_DIR defaults to ./uploads (relative to backend/)
BASE_URL=http://localhost:8000

# Email (OTP) — leave blank to print codes to console instead of sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@amadoo.app

# Social OAuth (leave blank until needed)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

ENVIRONMENT=development
